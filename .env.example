# ============================================================
# PRIM IDFM
# ============================================================
# Ta clé API récupérée sur prim.iledefrance-mobilites.fr
PRIM_API_KEY=your_prim_api_key_here

# ============================================================
# KAFKA
# ============================================================
# Adresse du broker Kafka
# - En local (hors Docker) : localhost:9092
# - Dans un container Docker : kafka:29092
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# ============================================================
# TOPICS
# ============================================================
KAFKA_TOPIC_PASSAGES=transit.raw.passages
KAFKA_TOPIC_ALERTS=transit.raw.alerts

# ============================================================
# POLLING
# ============================================================
# Intervalle en secondes entre chaque appel API
POLL_INTERVAL_SECONDS=60
